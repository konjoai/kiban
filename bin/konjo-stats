#!/usr/bin/env python3
"""konjo-stats: print per-specialist gate verdicts from the review log.

Folds a review-log file into dispatches, findings, hit rate, and a tag per specialist:
ACTIVE (earning its place), GATE_CANDIDATE (zero findings over the sample floor, review
for pruning), NEVER_GATE (insurance set, kept regardless), INSUFFICIENT_DATA (below the
floor; no recommendation made).

Usage:
  konjo-stats --log review/<branch>-reviews.jsonl [--floor 10] [--json]
  konjo-stats --branch <branch>     # resolves the log path for you
"""

from __future__ import annotations

import argparse
import json
import pathlib
import sys

_KIBAN_ROOT = pathlib.Path(__file__).resolve().parent.parent
if str(_KIBAN_ROOT) not in sys.path:
    sys.path.insert(0, str(_KIBAN_ROOT))

from lib import review_log, specialist_stats  # noqa: E402


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="konjo-stats")
    parser.add_argument("--log", default=None, help="review-log path (under the state dir)")
    parser.add_argument("--branch", default=None, help="resolve the log path from a branch")
    parser.add_argument("--floor", type=int, default=specialist_stats.DEFAULT_FLOOR)
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args(argv)

    if args.log:
        log_path = args.log
    elif args.branch:
        log_path = review_log.log_path_for(args.branch)
    else:
        print("usage: konjo-stats --log PATH | --branch NAME", file=sys.stderr)
        return 2

    stats = specialist_stats.compute(log_path, floor=args.floor)
    if args.json:
        print(json.dumps(
            {n: {"dispatches": s.dispatches, "findings": s.findings,
                 "hit_rate": round(s.hit_rate, 3), "tag": s.tag}
             for n, s in stats.items()},
            indent=2,
        ))
    else:
        print(specialist_stats.format_table(stats))
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
