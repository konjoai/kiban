#!/usr/bin/env python3
"""konjo-secrets: the session/pre-commit secret gate with the MEDIUM confirm.

  konjo-secrets scan --diff PATH        (PATH may be - for stdin)

HIGH findings block outright (exit 1), unchanged from the store and the CI gate. MEDIUM
findings route to the interactive confirm: the human affirms they are non-secrets or
intended (exit 0), or aborts (exit 2). This is the session path; CI keeps MEDIUM as a
non-blocking warn and never prompts.
"""

from __future__ import annotations

import argparse
import pathlib
import sys

_KIBAN_ROOT = pathlib.Path(__file__).resolve().parent.parent
if str(_KIBAN_ROOT) not in sys.path:
    sys.path.insert(0, str(_KIBAN_ROOT))

from lib import confirm, redact  # noqa: E402


def _read_diff(path: str | None) -> str:
    if not path or path == "-":
        return sys.stdin.read()
    return pathlib.Path(path).read_text(encoding="utf-8")


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="konjo-secrets")
    sub = parser.add_subparsers(dest="cmd", required=True)
    p = sub.add_parser("scan")
    p.add_argument("--diff", default="-", help="path to a diff, or - for stdin")
    args = parser.parse_args(argv)

    findings = redact.scan_diff(_read_diff(args.diff))
    high = [f for f in findings if f.tier is redact.Tier.HIGH]
    medium = [f for f in findings if f.tier is redact.Tier.MEDIUM]

    if high:
        names = ", ".join(sorted({f.pattern_name for f in high}))
        print(f"konjo-secrets: HIGH secret(s) on added lines, blocked: {names}", file=sys.stderr)
        return 1

    if medium:
        try:
            confirm.confirm_medium_secret(medium)
        except confirm.ConfirmAborted as exc:
            print(f"konjo-secrets: {exc}", file=sys.stderr)
            return 2
        print("konjo-secrets: MEDIUM finding(s) confirmed as non-secret")
        return 0

    print("konjo-secrets: no findings on added lines")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
