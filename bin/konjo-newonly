#!/usr/bin/env python3
"""konjo-newonly: report only net-new scanner findings versus a base ref.

This is what lets a strict gate run against an existing codebase without drowning in
pre-existing findings. Run the scanner on HEAD and on the merge-base of HEAD and the
given base. Diff the two finding sets line-insensitively (line numbers normalized
away). Report and exit nonzero ONLY on findings that exist on HEAD and not at the
merge-base. Pre-existing findings never block.

Usage:
  konjo-newonly --base <ref> -- <scanner-cmd...>

Example:
  konjo-newonly --base origin/main -- ruff check .
"""

from __future__ import annotations

import argparse
import re
import shutil
import subprocess
import sys
import tempfile

# Strip leading "path:line:col" location prefixes so the same finding on a shifted line
# normalizes to one comparable string. Also collapse bare line/col numbers.
_LOCATION_RE = re.compile(r"^([^\s:]+):\d+(?::\d+)?")
_NUM_RE = re.compile(r"\b\d+\b")


def _normalize(line: str) -> str:
    line = line.rstrip("\n")
    line = _LOCATION_RE.sub(lambda m: m.group(1) + ":N", line)
    line = _NUM_RE.sub("N", line)
    return line.strip()


def _run(cmd: list[str], cwd: str | None = None) -> str:
    proc = subprocess.run(cmd, capture_output=True, text=True, cwd=cwd)
    return proc.stdout + proc.stderr


def _git(args: list[str]) -> str:
    proc = subprocess.run(["git", *args], capture_output=True, text=True)
    return proc.stdout.strip()


def _git_ok(args: list[str]) -> bool:
    return subprocess.run(["git", *args], capture_output=True, text=True).returncode == 0


def _worktree_supported() -> bool:
    return _git_ok(["worktree", "list"])


def _findings_at_head(scanner: list[str]) -> set[str]:
    """Scan the current working tree (HEAD plus any local changes) in place."""
    out = _run(scanner)
    return {_normalize(line) for line in out.splitlines() if line.strip()}


def _findings_at_base(ref: str, scanner: list[str]) -> set[str]:
    """Scan the base ref WITHOUT touching the user's working tree (C3).

    Preferred path: check the ref out into a throwaway `git worktree` and run the
    scanner there. The caller's tree is never modified, so this is safe even with
    uncommitted changes. If worktrees are unavailable, the caller has already gated on
    a clean tree, so this falls back to an in-place checkout-and-restore.
    """
    if _worktree_supported():
        tmp = tempfile.mkdtemp(prefix="konjo-newonly-")
        try:
            if not _git_ok(["worktree", "add", "--quiet", "--detach", tmp, ref]):
                return set()
            out = _run(scanner, cwd=tmp)
            return {_normalize(line) for line in out.splitlines() if line.strip()}
        finally:
            _git(["worktree", "remove", "--force", tmp])
            shutil.rmtree(tmp, ignore_errors=True)

    # Fallback: in-place checkout. Only reached on a clean tree (gated in main).
    original = _git(["rev-parse", "--abbrev-ref", "HEAD"])
    if original == "HEAD":
        original = _git(["rev-parse", "HEAD"])
    try:
        _git(["checkout", "--quiet", ref])
        out = _run(scanner)
        return {_normalize(line) for line in out.splitlines() if line.strip()}
    finally:
        _git(["checkout", "--quiet", original])


def _tree_is_dirty() -> bool:
    return bool(_git(["status", "--porcelain"]))


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="konjo-newonly", add_help=True)
    parser.add_argument("--base", required=True, help="base ref to diff findings against")
    parser.add_argument("scanner", nargs=argparse.REMAINDER,
                        help="-- then the scanner command")
    args = parser.parse_args(argv)

    scanner = args.scanner
    if scanner and scanner[0] == "--":
        scanner = scanner[1:]
    if not scanner:
        print("usage: konjo-newonly --base <ref> -- <scanner-cmd...>", file=sys.stderr)
        return 2

    merge_base = _git(["merge-base", "HEAD", args.base])
    if not merge_base:
        print(f"could not find merge-base of HEAD and {args.base}", file=sys.stderr)
        return 2

    # C3: the base scan must not clobber the user's tree. We use a git worktree when
    # available. Only if worktrees are unavailable do we need a clean tree, since the
    # fallback checks out in place; refuse there rather than risk losing work.
    if not _worktree_supported() and _tree_is_dirty():
        print(
            "konjo-newonly: working tree is dirty and git worktree is unavailable.\n"
            "Commit or stash your changes, or use a git version with worktree support.",
            file=sys.stderr,
        )
        return 2

    head_findings = _findings_at_head(scanner)
    base_findings = _findings_at_base(merge_base, scanner)

    net_new = sorted(head_findings - base_findings)
    if not net_new:
        print("konjo-newonly: no net-new findings")
        return 0

    print(f"konjo-newonly: {len(net_new)} net-new finding(s):")
    for line in net_new:
        print(f"  {line}")
    return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
